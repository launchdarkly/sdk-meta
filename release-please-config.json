{
  "separate-pull-requests": false,
  "include-component-in-tag" : true,
  "bump-minor-pre-major": true,
  "packages" : {
    "api" : {
      "package-name": "api",
      "release-type" : "go",
      "tag-separator": "/",
      "versioning" : "default"
    },
    "api-js" : {
      "package-name": "api-js",
      "release-type" : "node",
      "tag-separator": "/",
      "versioning" : "default"
    },
    "snippets" : {
      "package-name": "snippets",
      "release-type" : "go",
      "tag-separator": "/",
      "versioning" : "default",
      "extra-files": [
        "internal/version/version.go"
      ]
    }
  }
}
